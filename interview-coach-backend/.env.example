# ── Database ────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/interview_coach

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_ME_WITH_A_64_CHAR_HEX_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_TOKEN_SESSION_DAYS=1

# ── Ollama (Phase 2) ─────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Whisper (Phase 2) ────────────────────────────────────────────────────────
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
